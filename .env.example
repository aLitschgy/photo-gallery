# Configuration de l'application

# Mot de passe pour l'accès admin
PASSWORD=mypassword

# Secret pour signer les tokens JWT (minimum 32 caractères recommandés)
SESSION_SECRET=supersecret

# Port du serveur (défaut: 3000)
PORT=3000

# Limite de taille des requêtes en octets (défaut: 512 Ko)
# 52428800 = 50 Mo pour les uploads de photos
BODY_SIZE_LIMIT=52428800
